        window.resetData = resetData;
        window.switchTab = switchTab;
        window.loadBreakageData = loadBreakageData;
        window.saveBreakageData = saveBreakageData;
        
        // --- INICIALIZAÇÃO FIREBASE ---
        document.getElementById('currentDate').innerText = new Date().toLocaleDateString('pt-BR');
        
        try {
            const app = initializeApp(MEU_FIREBASE_CONFIG);
            auth = getAuth(app);
            db = getFirestore(app);
        } catch(e) {
            console.error("Erro critico inicializando Firebase. Verifique as chaves.", e);
        }

        const initAuth = async () => {
            try {
                await signInAnonymously(auth);
            } catch(e) {
                console.error("Falha ao autenticar anonimamente na nuvem:", e);
                document.getElementById('cloudIndicator').innerHTML = '<i class="fa-solid fa-cloud-arrow-down text-red-500"></i> <span class="text-xs">Erro de Conexão</span>';
            }
        };
        
        initAuth();

        onAuthStateChanged(auth, (user) => {
            fbUser = user;
            if (user) {
                setupFirestoreListener();
                checkAppLogin();
            }
        });

        // --- LÓGICA DE DADOS EM NUVEM (FIRESTORE) ---
        function setupFirestoreListener() {
            if (!fbUser) return;
            
            // Ouvindo alterações em TEMPO REAL de todas as lojas
            const auditsRef = collection(db, 'artifacts', appId, 'audits');
            
            onSnapshot(auditsRef, (snapshot) => {
                let hasData = false;
                snapshot.forEach(doc => {
                    const storeId = doc.id;
                    if (Lojas.includes(storeId)) {
                        appData[storeId] = doc.data();
                        
                        if(!appData[storeId].breakage) appData[storeId].breakage = {};
                        
                        hasData = true;
                    }
                });

                const cloudInd = document.getElementById('cloudIndicator');
                if(cloudInd) cloudInd.innerHTML = '<i class="fa-solid fa-cloud text-emerald-500"></i> <span class="text-xs font-bold text-emerald-600">Nuvem Conectada</span>';

                if (!hasData) {
                     initEmptyDataCloud();
                } else {
                     refreshCurrentView();
                }
            }, (error) => {
                console.error("Erro Nuvem:", error);
                const cloudInd = document.getElementById('cloudIndicator');
                if(cloudInd) cloudInd.innerHTML = '<i class="fa-solid fa-cloud-arrow-down text-red-500"></i> <span class="text-xs">Erro Firestore</span>';
            });
        }

        async function initEmptyDataCloud() {
            if (!fbUser) return;
            Lojas.forEach(async loja => {
                if(!appData[loja]) appData[loja] = {};
                if(!appData[loja].breakage) appData[loja].breakage = {};
                
                cronogramaDiario.forEach(dia => {
                    if(!appData[loja].breakage[dia.data]) appData[loja].breakage[dia.data] = { val: '', nf: '' };
                });

                BaseItems.forEach(item => {
                    if(!appData[loja][item.id]) appData[loja][item.id] = { av: '', pk: '', dp: '' };
                });
                try {
                    const storeRef = doc(db, 'artifacts', appId, 'audits', loja);
                    await setDoc(storeRef, appData[loja]);
                } catch(e){}
            });
        }

        let saveTimeout;
        window.handleInput = function(storeId, itemId, field, value) {
            if (!appData[storeId]) appData[storeId] = {};
            if (!appData[storeId][itemId]) appData[storeId][itemId] = { av: '', pk: '', dp: '' };

            appData[storeId][itemId][field] = value;

            // UI
            const item = BaseItems.find(i => i.id === itemId);
            const d = appData[storeId][itemId];
            let isFilled = d.av !== '' || d.pk !== '' || d.dp !== '';
            
            if (isFilled) {
                const calc = calcItem(item.ideal, d.av, d.pk, d.dp);
                document.getElementById(`tot-${itemId}`).innerText = calc.total;
                document.getElementById(`rup-${itemId}`).innerText = calc.ruptura + '%';
                document.getElementById(`rup-${itemId}`).className = `px-4 py-3 text-center font-bold ${calc.ruptura > 20 ? 'text-red-600' : 'text-slate-600'}`;
                document.getElementById(`badge-${itemId}`).innerHTML = getStatusBadge(calc.ruptura);
            } else {
                document.getElementById(`tot-${itemId}`).innerText = '-';
                document.getElementById(`rup-${itemId}`).innerText = '-';
                document.getElementById(`badge-${itemId}`).innerHTML = getStatusBadge(null);
            }

            clearTimeout(window.storeDashboardTimer);
            window.storeDashboardTimer = setTimeout(() => { updateStoreHeader(storeId); }, 500);

            // Debounce DB Save
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(() => {
                saveSpecificStore(storeId);
            }, 1000);
        }

        // --- LÓGICA DE QUEBRA FINANCEIRA ---
        function loadBreakageData() {
            const dateSelect = document.getElementById('breakageDate');
            if(!dateSelect) return;
            const date = dateSelect.value;
            const storeId = currentActiveStore;
            
            if(appData[storeId] && appData[storeId].breakage && appData[storeId].breakage[date]) {
                document.getElementById('breakageValue').value = appData[storeId].breakage[date].val || '';
                document.getElementById('breakageNF').value = appData[storeId].breakage[date].nf || '';
            } else {
                document.getElementById('breakageValue').value = '';
                document.getElementById('breakageNF').value = '';
            }
        }

        function saveBreakageData() {
            const date = document.getElementById('breakageDate').value;
            const val = document.getElementById('breakageValue').value;
            const nf = document.getElementById('breakageNF').value;
            const storeId = currentActiveStore;
            
            if(!appData[storeId]) appData[storeId] = {};
            if(!appData[storeId].breakage) appData[storeId].breakage = {};
            
            appData[storeId].breakage[date] = { val: val, nf: nf };
            
            saveSpecificStore(storeId);
            
            const feedback = document.getElementById('breakageSaveFeedback');
            feedback.style.opacity = '1';
            setTimeout(() => { feedback.style.opacity = '0'; }, 2000);
        }

        async function saveSpecificStore(storeId) {
            if (fbUser) {
                try {
                    const storeRef = doc(db, 'artifacts', appId, 'audits', storeId);
                    await setDoc(storeRef, appData[storeId]);
                    showSaveIndicator();
                } catch(e) { console.error("Erro salvando na nuvem", e); }
            } 
        }

        function showSaveIndicator() {
            const indicator = document.getElementById('saveIndicator');
            if(indicator) {
                indicator.innerHTML = '<i class="fa-solid fa-cloud-arrow-up"></i> Sincronizado na Nuvem';
                indicator.className = 'text-xs font-semibold px-3 py-1 rounded-full flex items-center gap-1 shadow-sm transition-opacity duration-300 opacity-100 bg-blue-100 text-blue-800';
                setTimeout(() => { indicator.style.opacity = '0'; }, 2500);
            }
        }

        // --- SISTEMA DE LOGIN DA APLICAÇÃO ---
        function toggleLoginFields() {
            const type = document.getElementById('loginType').value;
            const storeField = document.getElementById('storeSelectField');
            if(type === 'admin') storeField.style.display = 'none';
            else storeField.style.display = 'block';
        }

        function checkAppLogin() {
            const storedUser = sessionStorage.getItem('komprao_session');
            if(storedUser) {
                authUser = storedUser;
                showApp();
            } else {
                document.getElementById('login-overlay').style.display = 'flex';
                document.getElementById('main-app').classList.add('hidden-view');
            }
        }

        function performLogin() {
            const type = document.getElementById('loginType').value;
            const pass = document.getElementById('loginPassword').value;
            const store = document.getElementById('loginStore').value;
            const errorLabel = document.getElementById('loginError');

            errorLabel.classList.add('hidden-view');

            if(type === 'admin') {
                if(pass === 'admin') {
                    authUser = 'admin';
                    finishLogin();
                } else {
                    errorLabel.classList.remove('hidden-view');
                }
            } else {
                if(pass === 'loja' + store) {
                    authUser = store;
                    finishLogin();
                } else {
                    errorLabel.classList.remove('hidden-view');
                }
            }
        }

        function finishLogin() {
            sessionStorage.setItem('komprao_session', authUser);
            document.getElementById('loginPassword').value = '';
            document.getElementById('login-overlay').style.display = 'none';
            showApp();
        }

        function performLogout() {
            sessionStorage.removeItem('komprao_session');
            authUser = null;
            document.getElementById('main-app').classList.add('hidden-view');
            document.getElementById('login-overlay').style.display = 'flex';
        }

        function showApp() {
            document.getElementById('main-app').classList.remove('hidden-view');
            
            const headerRole = document.getElementById('headerUserRole');
            if(authUser === 'admin') {
                headerRole.innerText = 'Acesso Administrador - Regional Sul';
                document.getElementById('btnResetData').style.display = 'block';
            } else {
                headerRole.innerText = 'Acesso Loja ' + authUser;
                document.getElementById('btnResetData').style.display = 'none';
            }

            populateDateFilter();
            populateBreakageDates();
            renderTabs();
            renderCronogramaCards();

            if(authUser === 'admin') switchTab('regional');
            else switchTab(authUser);
            
            refreshCurrentView();
        }

        function refreshCurrentView() {
            if(!authUser) return;
            if(currentActiveStore === 'regional') {
                updateRegionalView();
            } else if (currentActiveStore !== 'cronograma') {
                const search = document.getElementById('searchInput') ? document.getElementById('searchInput').value : '';
                const dFilt = document.getElementById('dateFilter') ? document.getElementById('dateFilter').value : 'all';
                renderStoreTable(currentActiveStore, search, dFilt);
                updateStoreHeader(currentActiveStore);
                loadBreakageData();
            }
        }

        // --- BACKUP E IMPORTAÇÃO ---
        function exportData() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(appData, null, 2));
            const downloadAnchorNode = document.createElement('a');
            downloadAnchorNode.setAttribute("href", dataStr);
            downloadAnchorNode.setAttribute("download", `backup_nuvem_auditoria_komprao.json`);
            document.body.appendChild(downloadAnchorNode); 
            downloadAnchorNode.click();
            downloadAnchorNode.remove();
        }

        async function importData(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = async function(e) {
                try {
                    const importedData = JSON.parse(e.target.result);
                    
                    if (fbUser) {
                        const cloudInd = document.getElementById('cloudIndicator');
                        cloudInd.innerHTML = '<i class="fa-solid fa-spinner fa-spin text-komprao-blue"></i> <span class="text-xs">Restaurando Nuvem...</span>';

                        for(const loja of Lojas) {
                            if (importedData[loja]) {
                                if(!appData[loja]) appData[loja] = {};
                                
                                if(importedData[loja].breakage) {
                                    appData[loja].breakage = importedData[loja].breakage;
                                }

                                BaseItems.forEach(item => {
                                    if (importedData[loja][item.id]) {
                                        appData[loja][item.id] = importedData[loja][item.id];
                                    }
                                });
                                const storeRef = doc(db, 'artifacts', appId, 'audits', loja);
                                await setDoc(storeRef, appData[loja]);
                            }
                        }
                        alert("Dados restaurados com sucesso para a NUVEM!");
                    } 
                    refreshCurrentView();
                } catch (error) {
                    alert("Erro ao ler o arquivo. Certifique-se de que é um backup válido.");
                }
            };
            reader.readAsText(file);
            event.target.value = ''; 
        }

        async function resetData() {
            if(authUser !== 'admin') {
                alert("Apenas administradores podem limpar o banco de dados.");
                return;
            }
            if(confirm("ATENÇÃO: Deseja apagar TODOS os dados da NUVEM de TODAS as lojas? Faça um backup antes!")) {
                
                if(fbUser) {
                    for(const loja of Lojas) {
                        appData[loja] = {};
                        appData[loja].breakage = {};
                        cronogramaDiario.forEach(dia => {
                            appData[loja].breakage[dia.data] = { val: '', nf: '' };
                        });
                        BaseItems.forEach(item => {
                            appData[loja][item.id] = { av: '', pk: '', dp: '' };
                        });
                        const storeRef = doc(db, 'artifacts', appId, 'audits', loja);
                        await setDoc(storeRef, appData[loja]);
                    }
                    alert("Nuvem limpa com sucesso.");
                }
                refreshCurrentView();
            }
        }

        // --- INTERFACE (TABS & SELECTORS) ---
        function populateDateFilter() {
            const select = document.getElementById('dateFilter');
            if(!select) return;
            select.innerHTML = '<option value="all">Todos os Dias</option>';
            cronogramaDiario.forEach(dia => {
                select.innerHTML += `<option value="${dia.data}">${dia.data} - ${dia.dia} (${dia.lista})</option>`;
            });
            
            select.addEventListener('change', () => {
                if(currentActiveStore !== 'regional' && currentActiveStore !== 'cronograma') {
                    renderStoreTable(currentActiveStore, document.getElementById('searchInput').value, select.value);
                }
            });
        }

        function populateBreakageDates() {
            const sel = document.getElementById('breakageDate');
            if(!sel) return;
            sel.innerHTML = '';
            cronogramaDiario.forEach(dia => {
                sel.innerHTML += `<option value="${dia.data}">${dia.data} - ${dia.dia}</option>`;
            });
        }

        function getListaBadgeClass(lista) {
            const letter = lista.replace('Lista ', '');
            const cycle = {
                'A': 'bg-blue-100 text-blue-800', 'F': 'bg-blue-100 text-blue-800', 'K': 'bg-blue-100 text-blue-800', 'P': 'bg-blue-100 text-blue-800',
                'B': 'bg-emerald-100 text-emerald-800', 'G': 'bg-emerald-100 text-emerald-800', 'L': 'bg-emerald-100 text-emerald-800', 'Q': 'bg-emerald-100 text-emerald-800',
                'C': 'bg-amber-100 text-amber-800', 'H': 'bg-amber-100 text-amber-800', 'M': 'bg-amber-100 text-amber-800', 'R': 'bg-amber-100 text-amber-800',
                'D': 'bg-purple-100 text-purple-800', 'I': 'bg-purple-100 text-purple-800', 'N': 'bg-purple-100 text-purple-800', 'S': 'bg-purple-100 text-purple-800',
                'E': 'bg-komprao-red text-white', 'J': 'bg-komprao-red text-white', 'O': 'bg-komprao-red text-white', 'T': 'bg-komprao-red text-white'
            };
            return cycle[letter] || "bg-slate-100 text-slate-800";
        }

        function renderCronogramaCards() {
            const container = document.getElementById('detailed-schedule-container');
            if(!container) return;
            container.innerHTML = '';
            
            cronogramaDiario.forEach(dia => {
                let htmlCat = dia.categorias.map(cat => `<li class="flex items-start gap-2 text-sm text-slate-600 mb-1"><i class="fa-solid fa-check text-emerald-500 mt-1"></i> <span>${cat}</span></li>`).join('');
                
                const card = `
                <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-start mb-3 border-b border-slate-100 pb-2">
                        <div>
                            <p class="font-bold text-slate-800 text-lg">${dia.data}</p>
                            <p class="text-xs text-slate-500 font-medium uppercase">${dia.dia}</p>
                        </div>
                        <span class="badge ${getListaBadgeClass(dia.lista)}">${dia.lista}</span>
                    </div>
                    <ul class="pt-1">
                        ${htmlCat}
                    </ul>
                </div>
                `;
                container.innerHTML += card;
            });
        }

        function renderTabs() {
            const container = document.getElementById('tabsContainer');
            if(!container) return;
            let html = '';

            if (authUser === 'admin') {
                html += `<button onclick="switchTab('regional')" id="tab-regional" class="px-4 py-3 text-sm font-medium rounded-t-lg transition-colors text-slate-500">
                            <i class="fa-solid fa-chart-pie mr-2"></i>Visão Regional
                        </button>`;
            }

            html += `<button onclick="switchTab('cronograma')" id="tab-cronograma" class="px-4 py-3 text-sm font-medium text-slate-500 hover:text-komprao-blue transition-colors">
                        <i class="fa-regular fa-calendar-days mr-2"></i>Cronograma
                    </button>`;
            
            if (authUser === 'admin') {
                Lojas.forEach(loja => {
                    html += `<button onclick="switchTab('${loja}')" id="tab-${loja}" class="px-4 py-3 text-sm font-medium text-slate-500 hover:text-komprao-blue transition-colors">
                                Loja ${loja}
                            </button>`;
                });
            } else if (authUser) {
                html += `<button onclick="switchTab('${authUser}')" id="tab-${authUser}" class="px-4 py-3 text-sm font-medium text-slate-500 hover:text-komprao-blue transition-colors">
                            Minha Loja (${authUser})
                        </button>`;
            }

            container.innerHTML = html;
        }

        function switchTab(tabId) {
            document.querySelectorAll('#tabsContainer button').forEach(b => {
                b.classList.remove('tab-active');
                b.classList.add('text-slate-500');
            });
            
            const activeBtn = document.getElementById(`tab-${tabId}`);
            if(activeBtn) {
                activeBtn.classList.add('tab-active');
                activeBtn.classList.remove('text-slate-500');
            }

            currentActiveStore = tabId;
            document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden-view'));

            if (tabId === 'regional') {
                document.getElementById('view-regional').classList.remove('hidden-view');
                updateRegionalView();
            } else if (tabId === 'cronograma') {
                document.getElementById('view-cronograma').classList.remove('hidden-view');
            } else {
                document.getElementById('view-loja').classList.remove('hidden-view');
                document.getElementById('currentStoreName').innerText = `Loja ${tabId}`;
                const srcInp = document.getElementById('searchInput');
                const dtFilt = document.getElementById('dateFilter');
                if(srcInp) srcInp.value = ''; 
                if(dtFilt) dtFilt.value = 'all'; 
                renderStoreTable(tabId);
                updateStoreHeader(tabId);
                loadBreakageData();
            }
        }

        function calcItem(ideal, av, pk, dp) {
            let nAV = parseInt(av) || 0;
            let nPK = parseInt(pk) || 0;
            let nDP = parseInt(dp) || 0;
            
            let totalEnc = nAV + nPK + nDP;
            let encCalc = totalEnc > ideal ? ideal : totalEnc;
            let ruptura = ideal > 0 ? ((ideal - encCalc) / ideal) * 100 : 0;
            
            return { total: totalEnc, ruptura: ruptura.toFixed(1) };
        }

        function getStatusBadge(rup) {
            if (rup === null || rup === '') return `<span class="badge bg-slate-200 text-slate-500">Pendente</span>`;
            if (rup <= 5) return `<span class="badge bg-success">Regular</span>`;
            if (rup <= 20) return `<span class="badge bg-warning">Atenção</span>`;
            return `<span class="badge bg-danger">Crítico</span>`;
        }

        function renderStoreTable(storeId, filter = '', dateFilt = 'all') {
            const tbody = document.getElementById('storeTableBody');
            if(!tbody) return;
            tbody.innerHTML = '';
            const filterLower = filter.toLowerCase();

            BaseItems.forEach(item => {
                if (dateFilt !== 'all' && item.data !== dateFilt) return; 
                if (filter && !item.cat.toLowerCase().includes(filterLower) && !item.sub.toLowerCase().includes(filterLower)) return;

                const data = (appData[storeId] && appData[storeId][item.id]) ? appData[storeId][item.id] : { av: '', pk: '', dp: '' };
                
                let isFilled = data.av !== '' || data.pk !== '' || data.dp !== '';
                let calc = isFilled ? calcItem(item.ideal, data.av, data.pk, data.dp) : {total: '-', ruptura: null};

                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50 transition-colors";
                tr.innerHTML = `
                    <td class="px-4 py-3">
                        <p class="font-semibold text-slate-800">${item.cat}</p>
                        <p class="text-xs text-slate-500">${item.sub}</p>
                        <span class="inline-block mt-1 px-2 py-0.5 bg-slate-200 text-slate-600 rounded text-[10px] font-bold"><i class="fa-regular fa-calendar mr-1"></i>${item.data}</span>
                    </td>
                    <td class="px-4 py-3 text-center font-bold text-slate-600">${item.ideal}</td>
                    <td class="px-4 py-3 text-center bg-blue-50/30">
                        <input type="number" min="0" class="audit-input" value="${data.av}" onkeyup="handleInput('${storeId}', ${item.id}, 'av', this.value)">
                    </td>
                    <td class="px-4 py-3 text-center bg-purple-50/30">
                        <input type="number" min="0" class="audit-input" value="${data.pk}" onkeyup="handleInput('${storeId}', ${item.id}, 'pk', this.value)">
                    </td>
                    <td class="px-4 py-3 text-center bg-amber-50/30">
                        <input type="number" min="0" class="audit-input" value="${data.dp}" onkeyup="handleInput('${storeId}', ${item.id}, 'dp', this.value)">
                    </td>
                    <td class="px-4 py-3 text-center font-bold text-slate-800" id="tot-${item.id}">${calc.total}</td>
                    <td class="px-4 py-3 text-center font-bold ${calc.ruptura > 20 ? 'text-red-600' : 'text-slate-600'}" id="rup-${item.id}">
                        ${calc.ruptura !== null ? calc.ruptura + '%' : '-'}
                    </td>
                    <td class="px-4 py-3 text-center" id="badge-${item.id}">
                        ${getStatusBadge(calc.ruptura)}
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function updateStoreHeader(storeId) {
            let preenchidos = 0;
            let somaRuptura = 0;
            let contRuptura = 0;
            
            let countRegular = 0, countCritical = 0;
            let locAV = 0, locPK = 0, locDP = 0;
            
            let storeCatStats = {};

            BaseItems.forEach(item => {
                const d = (appData[storeId] && appData[storeId][item.id]) ? appData[storeId][item.id] : { av: '', pk: '', dp: '' };
                if (d.av !== '' || d.pk !== '' || d.dp !== '') {
                    preenchidos++;
                    let c = calcItem(item.ideal, d.av, d.pk, d.dp);
                    let rup = parseFloat(c.ruptura);
                    
                    somaRuptura += rup;
                    contRuptura++;

                    if(rup <= 5) countRegular++;
                    if(rup > 20) countCritical++;

                    locAV += parseInt(d.av) || 0;
                    locPK += parseInt(d.pk) || 0;
                    locDP += parseInt(d.dp) || 0;

                    if(!storeCatStats[item.cat]) storeCatStats[item.cat] = { sumRup: 0, count: 0 };
                    storeCatStats[item.cat].sumRup += rup;
                    storeCatStats[item.cat].count++;
                }
            });

            const prog = ((preenchidos / BaseItems.length) * 100).toFixed(0);
            const rupMedia = contRuptura > 0 ? (somaRuptura / contRuptura).toFixed(1) : 0;

            const elProgTxt = document.getElementById('loja-progresso-txt');
            if(elProgTxt) elProgTxt.innerText = `${prog}%`;
            
            const elRupTxt = document.getElementById('loja-ruptura-txt');
            if(elRupTxt) elRupTxt.innerText = `${rupMedia}%`;
            
            const elStoreChck = document.getElementById('store-kpi-checked');
            if(elStoreChck) {
                elStoreChck.innerText = preenchidos;
                document.getElementById('store-kpi-pending').innerText = BaseItems.length - preenchidos;
                document.getElementById('store-kpi-regular').innerText = countRegular;
                document.getElementById('store-kpi-critical').innerText = countCritical;
            }

            renderStoreCharts(storeId, locAV, locPK, locDP, storeCatStats);
        }

        function renderStoreCharts(storeId, av, pk, dp, catStats) {
            const ctxLocEl = document.getElementById('chartStoreLocations');
            if(!ctxLocEl) return;
            
            if(chartsInstance.storePie) chartsInstance.storePie.destroy();
            if(chartsInstance.storeBar) chartsInstance.storeBar.destroy();

            const ctxLoc = ctxLocEl.getContext('2d');
            let hasDataLoc = av > 0 || pk > 0 || dp > 0;
            chartsInstance.storePie = new Chart(ctxLoc, {
                type: 'doughnut',
                data: {
                    labels: hasDataLoc ? ['Área de Venda', 'Picking', 'Depósito'] : ['Sem Dados'],
                    datasets: [{
                        data: hasDataLoc ? [av, pk, dp] : [1],
                        backgroundColor: hasDataLoc ? ['#3b82f6', '#9333ea', '#f59e0b'] : ['#e2e8f0'],
                        borderWidth: 2,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '65%',
                    plugins: { legend: { position: 'right', labels: { boxWidth: 10, font: { size: 10 } } } }
                }
            });

            const ctxCat = document.getElementById('chartStoreTopRuptura').getContext('2d');
            let sortedCats = Object.keys(catStats)
                .map(k => ({ name: k, media: catStats[k].sumRup / catStats[k].count }))
                .sort((a,b) => b.media - a.media)
                .slice(0, 4);

            chartsInstance.storeBar = new Chart(ctxCat, {
                type: 'bar',
                data: {
                    labels: sortedCats.length ? sortedCats.map(c => c.name.substring(0, 10) + '..') : ['Sem Dados'],
                    datasets: [{
                        label: '% Ruptura',
                        data: sortedCats.length ? sortedCats.map(c => c.media.toFixed(1)) : [0],
                        backgroundColor: '#dc0c24',
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { beginAtZero: true, max: 100 },
                        y: { grid: { display: false }, ticks: { font: { size: 10 } } }
                    }
                }
            });
        }

        // --- VISÃO REGIONAL ---
        function updateRegionalView() {
            let statsLojas = [];
            let totalAV = 0, totalPK = 0, totalDP = 0;
            let totalPreenchidos = 0;
            let itensPorLoja = BaseItems.length;
            let totalEsperado = itensPorLoja * Lojas.length;

            let itemStats = {};
            let regionalCatStats = {};
            
            let totalRegionalBreakage = 0;
            let regionalBreakagePerDay = {};
            cronogramaDiario.forEach(dia => { regionalBreakagePerDay[dia.data] = 0; });

            BaseItems.forEach(i => itemStats[i.id] = { sumRup: 0, count: 0, lojasFalta: 0, name: i.sub, cat: i.cat });

            Lojas.forEach(loja => {
                let sRup = 0, sCount = 0, preenchidoLoja = 0;
                
                if(appData[loja] && appData[loja].breakage) {
                    Object.keys(appData[loja].breakage).forEach(date => {
                        let bVal = parseFloat(appData[loja].breakage[date].val) || 0;
                        totalRegionalBreakage += bVal;
                        if(regionalBreakagePerDay[date] !== undefined) {
                            regionalBreakagePerDay[date] += bVal;
                        }
                    });
                }

                BaseItems.forEach(item => {
                    const d = (appData[loja] && appData[loja][item.id]) ? appData[loja][item.id] : { av: '', pk: '', dp: '' };
                    if (d.av !== '' || d.pk !== '' || d.dp !== '') {
                        preenchidoLoja++; totalPreenchidos++;
                        let calc = calcItem(item.ideal, d.av, d.pk, d.dp);
                        let r = parseFloat(calc.ruptura);
                        
                        sRup += r; sCount++;
                        totalAV += parseInt(d.av) || 0;
                        totalPK += parseInt(d.pk) || 0;
                        totalDP += parseInt(d.dp) || 0;

                        itemStats[item.id].sumRup += r;
                        itemStats[item.id].count++;
                        if (r > 0) itemStats[item.id].lojasFalta++;

                        if(!regionalCatStats[item.cat]) regionalCatStats[item.cat] = { sumRup: 0, count: 0 };
                        regionalCatStats[item.cat].sumRup += r;
                        regionalCatStats[item.cat].count++;
                    }
                });
                let mediaLoja = sCount > 0 ? (sRup / sCount) : 0;
                statsLojas.push({ loja: loja, ruptura: mediaLoja, preenchido: preenchidoLoja });
            });

            const elTotalBreakage = document.getElementById('reg-total-breakage');
            if(elTotalBreakage) {
                elTotalBreakage.innerText = totalRegionalBreakage.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
            }

            let mediaRegional = Lojas.length > 0 ? (statsLojas.reduce((a, b) => a + b.ruptura, 0) / Lojas.length) : 0;
            const elRegRupt = document.getElementById('reg-ruptura');
            if(elRegRupt) elRegRupt.innerText = mediaRegional.toFixed(1) + '%';
            
            const elRegProg = document.getElementById('reg-progresso');
            if(elRegProg) {
                let progGeral = ((totalPreenchidos / totalEsperado) * 100);
                elRegProg.innerText = progGeral.toFixed(0) + '%';
                document.getElementById('reg-progresso-bar').style.width = progGeral + '%';
                document.getElementById('reg-total-itens').innerText = totalEsperado;
            }

            let lojasAtivas = statsLojas.filter(s => s.preenchido > 0);
            if (lojasAtivas.length > 0) {
                let pior = lojasAtivas.reduce((prev, current) => (prev.ruptura > current.ruptura) ? prev : current);
                const elPior = document.getElementById('reg-pior-loja');
                if(elPior) {
                    elPior.innerText = `Loja ${pior.loja}`;
                    document.getElementById('reg-pior-loja-val').innerText = `${pior.ruptura.toFixed(1)}% de ruptura`;
                }
            } else {
                const elPior = document.getElementById('reg-pior-loja');
                if(elPior) {
                    elPior.innerText = `-`;
                    document.getElementById('reg-pior-loja-val').innerText = `Sem dados`;
                }
            }

            let sortedItems = Object.values(itemStats)
                                .filter(i => i.count > 0)
                                .map(i => ({...i, media: i.sumRup / i.count}))
                                .sort((a,b) => b.media - a.media)
                                .slice(0, 5); 

            const tBody = document.getElementById('regionalTableBody');
            if(tBody) {
                tBody.innerHTML = '';
                if (sortedItems.length === 0) {
                    tBody.innerHTML = `<tr><td colspan="3" class="px-6 py-4 text-center text-slate-500">Nenhum dado preenchido.</td></tr>`;
                } else {
                    sortedItems.forEach(i => {
                        tBody.innerHTML += `
                            <tr class="hover:bg-slate-50">
                                <td class="px-6 py-3"><span class="font-semibold">${i.cat}</span> <br><span class="text-xs text-slate-500">${i.name}</span></td>
                                <td class="px-6 py-3 text-center font-bold text-red-600">${i.media.toFixed(1)}%</td>
                                <td class="px-6 py-3 text-center"><span class="bg-slate-200 text-slate-700 py-1 px-2 rounded text-xs font-bold">${i.lojasFalta} / ${Lojas.length}</span></td>
                            </tr>
                        `;
                    });
                }
            }

            renderRegionalCharts(statsLojas, regionalCatStats, regionalBreakagePerDay);
        }

        function renderRegionalCharts(statsLojas, catStats, regionalBreakagePerDay) {
            const ctxBarEl = document.getElementById('chartLojas');
            if(!ctxBarEl) return;

            if(chartsInstance.regBar) chartsInstance.regBar.destroy();
            if(chartsInstance.regRadar) chartsInstance.regRadar.destroy();
            if(chartsInstance.regLine) chartsInstance.regLine.destroy();

            const ctxBar = ctxBarEl.getContext('2d');
            chartsInstance.regBar = new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: statsLojas.map(s => `Loja ${s.loja}`),
                    datasets: [{
                        label: '% Ruptura Média',
                        data: statsLojas.map(s => s.ruptura.toFixed(1)),
                        backgroundColor: statsLojas.map(s => s.ruptura > 20 ? '#dc0c24' : (s.ruptura > 10 ? '#f59e0b' : '#141848')),
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, max: 100, ticks: { callback: function(value){return value+"%"} } },
                        x: { grid: { display: false } }
                    }
                }
            });

            const ctxRadar = document.getElementById('chartCategoriasRegional').getContext('2d');
            let sortedCats = Object.keys(catStats).map(k => ({ name: k, media: catStats[k].sumRup / catStats[k].count })).sort((a,b) => b.media - a.media).slice(0, 5);
            
            chartsInstance.regRadar = new Chart(ctxRadar, {
                type: 'polarArea',
                data: {
                    labels: sortedCats.length ? sortedCats.map(c => c.name.substring(0,10)+'.') : ['Sem Dados'],
                    datasets: [{
                        data: sortedCats.length ? sortedCats.map(c => c.media.toFixed(1)) : [1],
                        backgroundColor: ['rgba(220,12,36,0.7)', 'rgba(20,24,72,0.7)', 'rgba(245,158,11,0.7)', 'rgba(16,185,129,0.7)', 'rgba(147,51,234,0.7)'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'right', labels: { boxWidth: 10, font: { size: 10 } } } },
                    scales: { r: { ticks: { display: false } } }
                }
            });

            const ctxLine = document.getElementById('chartRegionalBreakage').getContext('2d');
            let dates = cronogramaDiario.map(d => d.data);
            let breakages = dates.map(d => regionalBreakagePerDay[d]);

            chartsInstance.regLine = new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: dates,
                    datasets: [{
                        label: 'Quebra Financeira (R$)',
                        data: breakages,
                        borderColor: '#dc0c24',
                        backgroundColor: 'rgba(220,12,36,0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.3,
                        pointBackgroundColor: '#141848',
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, ticks: { callback: function(value){ return 'R$ ' + value; } } },
                        x: { grid: { display: false } }
                    }
                }
            });
        }
    </script>
</body>
</html>
